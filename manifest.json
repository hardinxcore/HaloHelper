{
   "action": {
      "default_popup": "popup.html"
   },
   "author": "Anton Broere - SEVENP",
   "background": {
      "service_worker": "background.js"
   },
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self';"
   },
   "description": "Adds buttons and functionality to HaloPSA",
   "icons": {
      "128": "/images/128.png",
      "16": "/images/16.png",
      "32": "/images/32.png",
      "48": "/images/48.png"
   },
   "manifest_version": 3,
   "name": "SEVENP Halo Enhancements",
   "omnibox": {
      "keyword": "HA"
   },
   "host_permissions": [ "*://*.sevenp.halopsa.com/*" ],
   "options_ui": {
      "open_in_tab": true,
      "page": "options.html"
   },
   "permissions": [ "tabs", "scripting", "storage", "cookies" ],
   "version": "1.0"
}
